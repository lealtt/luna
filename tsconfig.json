{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "rootDir": "./",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "baseUrl": "./src",
    "paths": {
      "#states": ["discord/states/index.ts"],
      "#discord/bootstrap": ["discord/base/bootstrap.ts"],
      "#discord/modules": ["discord/base/modules/index.ts"],
      "#discord/middlewares": ["discord/middlewares/index.ts"],
      "#discord/handlers": ["discord/base/handlers/index.ts"],
      "#discord/builders": ["discord/base/builders/index.ts"],
      "#database": ["database/index.ts"],
      "#utils": ["utils/index.ts"],
      "#emojisJson": ["../emojis.json"],
      "#settingsJson": ["../settings.json"],
      "#enJson": ["../locales/en-US/common.json"],
      "#enCommandsJson": ["../locales/en-US/commands.json"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "tsup.config.ts"]
}
